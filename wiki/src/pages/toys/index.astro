---
import Layout from '../../layouts/Layout.astro'
import { toys } from '../../lib/data'
import Sprite from '../../components/Sprite.astro'
import TierFilter from '../../components/TierFilter.astro'
import AbilityText from '../../components/AbilityText.astro'
import StatIcon from '../../components/StatIcon.astro'


const sorted = [...toys].sort((a, b) => a.tier - b.tier || a.name.localeCompare(b.name))
---
<Layout title="Toys" description="Browse all Super Auto Pets toys — effects, tiers, and shop costs.">
  <div class="page-header">
    <h1>Toys</h1>
    <span class="count">{toys.length} entries</span>
  </div>

  <TierFilter />

  <div class="gallery">
    {sorted.map(toy => (
      <a
        href={`/toys/${toy.slug}`}
        class:list={['card', !toy.active && 'card--inactive']}
        data-entry-tier={toy.tier}
        data-entry-name={toy.name.toLowerCase()}
        data-entry-desc={[toy.trigger, toy.ability1, toy.ability2, toy.ability3].filter(Boolean).join(' ').toLowerCase()}
      >
        <div class="card-image">
          <Sprite name={toy.name} image={toy.image} tier={toy.tier} size={120} />
        </div>

        <div class="card-body">
          <div class="card-name">{toy.name}</div>


          {!toy.rollable && toy.active && (
            <span class="card-flag">Token</span>
          )}
        </div>

        {(toy.ability1 || toy.trigger) && (
          <div class="skill-tooltip">
            {toy.trigger && (
              <div class="tt-trigger">{toy.trigger}</div>
            )}
            {toy.ability1 && (
              <div class="tt-level" data-level="1">
                <StatIcon name="Level1" size={22} />
                <AbilityText text={toy.ability1} iconSize={22} links={false} />
              </div>
            )}
            {toy.ability2 && (
              <div class="tt-level" data-level="2" hidden>
                <StatIcon name="Level2" size={22} />
                <AbilityText text={toy.ability2} iconSize={22} links={false} />
              </div>
            )}
            {toy.ability3 && (
              <div class="tt-level" data-level="3" hidden>
                <StatIcon name="Level3" size={22} />
                <AbilityText text={toy.ability3} iconSize={22} links={false} />
              </div>
            )}
            {(toy.ability2 || toy.ability3) && (
              <div class="tt-dots">
                {toy.ability1 && <span class="tt-dot tt-dot--active" data-dot="1" />}
                {toy.ability2 && <span class="tt-dot" data-dot="2" />}
                {toy.ability3 && <span class="tt-dot" data-dot="3" />}
              </div>
            )}
          </div>
        )}
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: var(--sp-5);
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .count {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
    gap: var(--sp-4);
  }

  .card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    color: var(--text);
    transition: box-shadow 150ms, transform 150ms, border-color 150ms;
    overflow: visible;
    text-decoration: none;
  }

  .card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-3px);
    border-color: var(--accent-border);
    z-index: 20;
  }

  .card--inactive {
    opacity: 0.5;
  }

  .card-image {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-5) var(--sp-4) var(--sp-3);
    background: var(--surface-muted);
    border-radius: var(--r-xl) var(--r-xl) 0 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .card-image :global(.sprite),
  .card-image :global(.sprite-ph) {
    width: 120px !important;
    height: 120px !important;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-4) var(--sp-4);
  }

  .card-name {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1.2;
  }

  .card-row {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .stat {
    font-size: 0.95rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  .card-flag {
    align-self: flex-start;
    font-size: 0.68rem;
    font-weight: 700;
    background: var(--accent-dim);
    color: var(--accent);
    padding: 2px 7px;
    border-radius: var(--r-sm);
  }

  /* tooltip */
  .skill-tooltip {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: var(--sp-3) var(--sp-4);
    box-shadow: var(--shadow);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 140ms, visibility 140ms;
    z-index: 50;
  }

  .tt-trigger {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: var(--sp-2);
  }

  .tt-level {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-2);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .tt-dots {
    display: flex;
    gap: 5px;
    margin-top: var(--sp-2);
    justify-content: center;
  }

  .tt-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
    transition: background 120ms;
  }

  .tt-dot--active {
    background: var(--accent);
  }

  @media (hover: hover) {
    .card:hover .skill-tooltip {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }

  @media (max-width: 500px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sp-3);
    }

    .card-image :global(.sprite),
    .card-image :global(.sprite-ph) {
      width: 90px !important;
      height: 90px !important;
    }
  }
</style>

<script>
  const gallery = document.querySelector('.gallery')
  if (gallery) {
    const state = new WeakMap<Element, number>()

    gallery.addEventListener('wheel', (e) => {
      const card = (e.target as Element).closest('.card')
      if (!card) return
      const tooltip = card.querySelector('.skill-tooltip')
      if (!tooltip) return

      e.preventDefault()

      const levels = tooltip.querySelectorAll<HTMLElement>('[data-level]')
      if (levels.length <= 1) return

      const current = state.get(card) ?? 1
      const next = Math.min(Math.max(current + (e.deltaY > 0 ? 1 : -1), 1), levels.length)
      if (next === current) return
      state.set(card, next)

      levels.forEach(el => { el.hidden = Number(el.dataset.level) !== next })
      tooltip.querySelectorAll<HTMLElement>('[data-dot]').forEach(dot => {
        dot.classList.toggle('tt-dot--active', Number(dot.dataset.dot) === next)
      })
    }, { passive: false })
  }
</script>
