---
interface Props {
  name: string
  image: string
  imageLegacy?: string
  tier: number
  size?: number
}

const { name, image, imageLegacy = '', tier, size = 48 } = Astro.props
const tierColors: Record<number, string> = {
  1: 'oklch(60% 0.14 145)',
  2: 'oklch(58% 0.16 210)',
  3: 'oklch(58% 0.18 270)',
  4: 'oklch(62% 0.20 55)',
  5: 'oklch(56% 0.22 25)',
  6: 'oklch(56% 0.20 310)',
}
const tc = tierColors[tier] ?? tierColors[1]
const hasLegacy = imageLegacy.length > 0
---
{image
  ? <>
      <img
        src={`/assets/${image}`}
        alt={name}
        width={size}
        height={size}
        loading="lazy"
        class:list={["sprite", hasLegacy && "sprite--new"]}
        style={`width:${size}px;height:${size}px`}
      />
      {hasLegacy && (
        <img
          src={`/assets/${imageLegacy}`}
          alt={`${name} (legacy)`}
          width={size}
          height={size}
          loading="lazy"
          class="sprite sprite--legacy"
          style={`width:${size}px;height:${size}px`}
        />
      )}
    </>
  : <div
      class="sprite-ph"
      style={`width:${size}px;height:${size}px;background:${tc};font-size:${Math.round(size * 0.42)}px`}
      role="img"
      aria-label={name}
    >
      {name[0].toUpperCase()}
    </div>
}

<style>
  .sprite {
    object-fit: contain;
    border-radius: var(--r-sm);
    flex-shrink: 0;
  }

  .sprite-ph {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r);
    color: oklch(99% 0.004 0);
    font-weight: 800;
    flex-shrink: 0;
    user-select: none;
  }

  /* legacy hidden by default; shown when html[data-skin="legacy"] */
  .sprite--legacy {
    display: none;
  }

  html[data-skin="legacy"] .sprite--new {
    display: none;
  }

  html[data-skin="legacy"] .sprite--legacy {
    display: block;
  }
</style>
