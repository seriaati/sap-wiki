---
import diceMapData from '@data/dice_map.json'

interface Props {
  tiers?: number[]
}

const { tiers = [1, 2, 3, 4, 5, 6] } = Astro.props

const sprites = (diceMapData as any).sprites as Record<string, { x: number; y: number; w: number; h: number }>
const imgW = (diceMapData as any).imageWidth as number
const imgH = (diceMapData as any).imageHeight as number
const image = (diceMapData as any).image as string

function diceStyle(tier: number, px: number): string {
  const sp = sprites[`Dice_${tier}`]
  if (!sp) return ''
  const scale = px / sp.h
  const bgW = Math.round(imgW * scale)
  const bgH = Math.round(imgH * scale)
  const bgX = Math.round(sp.x * scale)
  const bgY = Math.round(sp.y * scale)
  const w   = Math.round(sp.w * scale)
  return `width:${w}px;height:${px}px;background-image:url('/assets/${image}');background-position:-${bgX}px -${bgY}px;background-size:${bgW}px ${bgH}px`
}
---
<div class="filter-bar" id="filter-bar">
  <label class="search-wrap">
    <span class="sr-only">Search</span>
    <input
      type="search"
      id="filter-search"
      class="search-input"
      placeholder="Search…"
      autocomplete="off"
    />
    <button type="button" id="search-clear" class="search-clear" aria-label="Clear search" hidden>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </label>

  <div class="tier-pills" role="group" aria-label="Filter by tier">
    <button class="pill active" data-tier="0" type="button">All</button>
    {tiers.map(t => (
      <button class={`pill pill--${t}`} data-tier={t} type="button">
        <span class="pill-dice" role="img" aria-label={`Tier ${t}`} style={diceStyle(t, 26)} />
      </button>
    ))}
  </div>
</div>

<script>
  const bar        = document.getElementById('filter-bar')!
  const search     = document.getElementById('filter-search') as HTMLInputElement
  const clearBtn   = document.getElementById('search-clear') as HTMLButtonElement
  const pills      = bar.querySelectorAll<HTMLButtonElement>('[data-tier]')

  let activeTier = 0
  let query      = ''

  function syncURL() {
    const params = new URLSearchParams()
    if (query)       params.set('q', query)
    if (activeTier)  params.set('tier', String(activeTier))
    const qs = params.toString()
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname)
  }

  function apply() {
    document.querySelectorAll<HTMLElement>('[data-entry-tier]').forEach(el => {
      const tier   = Number(el.dataset.entryTier)
      const name   = (el.dataset.entryName ?? '').toLowerCase()
      const desc   = (el.dataset.entryDesc ?? '').toLowerCase()
      const ok     = (activeTier === 0 || tier === activeTier) && (name.includes(query) || desc.includes(query))
      el.hidden    = !ok
    })
  }

  // restore from URL on load
  const params = new URLSearchParams(location.search)
  const initTier = Number(params.get('tier') ?? 0)
  const initQ    = params.get('q') ?? ''

  if (initQ) {
    search.value = initQ
    query = initQ.toLowerCase().trim()
    updateClear()
  }
  if (initTier) {
    activeTier = initTier
    pills.forEach(p => {
      p.classList.toggle('active', Number(p.dataset.tier) === initTier)
    })
  }
  apply()

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      activeTier = Number(pill.dataset.tier)
      pills.forEach(p => p.classList.remove('active'))
      pill.classList.add('active')
      apply()
      syncURL()
    })
  })

  function updateClear() {
    clearBtn.hidden = search.value.length === 0
  }

  search.addEventListener('input', () => {
    query = search.value.toLowerCase().trim()
    apply()
    syncURL()
    updateClear()
  })

  clearBtn.addEventListener('click', () => {
    search.value = ''
    query = ''
    apply()
    syncURL()
    updateClear()
    search.focus()
  })
</script>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
    margin-bottom: var(--sp-5);
  }

  .search-wrap {
    flex: 1;
    min-width: 160px;
    max-width: 280px;
    position: relative;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  .search-input {
    width: 100%;
    padding: 7px 32px 7px 12px;
    border: 1.5px solid var(--border);
    border-radius: var(--r);
    background: var(--surface);
    color: var(--text);
    font-family: inherit;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 130ms;
    appearance: textfield;
  }

  .search-input::-webkit-search-cancel-button { display: none; }
  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--text-muted); }

  .search-clear {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    color: var(--text-muted);
    background: var(--surface-muted);
    transition: background 120ms, color 120ms;
  }

  .search-clear:hover {
    background: var(--border);
    color: var(--text);
  }

  .tier-pills {
    display: flex;
    gap: var(--sp-1);
    flex-wrap: wrap;
  }

  .pill-dice {
    display: inline-block;
    background-repeat: no-repeat;
  }

  .pill {
    padding: 5px 8px;
    border-radius: var(--r);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-secondary);
    background: var(--surface-muted);
    border: 1.5px solid transparent;
    transition: background 120ms, border-color 120ms;
  }

  .pill:hover { background: var(--border); }

  .pill.active {
    background: var(--accent-dim);
    border-color: var(--accent);
  }

  /* tier-tinted active states */
  .pill--1.active { background: oklch(60% 0.14 145 / 0.14); border-color: var(--tier-1); }
  .pill--2.active { background: oklch(58% 0.16 210 / 0.14); border-color: var(--tier-2); }
  .pill--3.active { background: oklch(58% 0.18 270 / 0.14); border-color: var(--tier-3); }
  .pill--4.active { background: oklch(62% 0.20  55 / 0.14); border-color: var(--tier-4); }
  .pill--5.active { background: oklch(56% 0.22  25 / 0.14); border-color: var(--tier-5); }
  .pill--6.active { background: oklch(56% 0.20 310 / 0.14); border-color: var(--tier-6); }
  .pill--7.active { background: oklch(56% 0.18  45 / 0.14); border-color: var(--tier-7, #b8860b); }
</style>
